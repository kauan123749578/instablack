# ============================================================
# Aplicação
# ============================================================
APP_ENV=development
SECRET_KEY=troque-isto-por-uma-chave-aleatoria-bem-longa
ALLOW_REGISTRATION=true
TRUST_PROXY=true

# ============================================================
# Banco de dados
#   Dev: sqlite:///./app.db
#   Railway: plugin Postgres injeta DATABASE_URL automaticamente
# ============================================================
DATABASE_URL=sqlite:///./app.db

# ============================================================
# Redis (broker do Celery)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Storage de mídia
#   local = dev (./storage) ou Railway Volume (/data/storage)
#   s3    = Cloudflare R2 ou AWS S3 (recomendado em produção)
# ============================================================
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# Cloudflare R2 (STORAGE_BACKEND=s3) — ver RAILWAY.md seção R2
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# ============================================================
# ffmpeg — instalado via nixpacks no Railway
# ============================================================
FFMPEG_BIN=ffmpeg

BEAT_TICK_SECONDS=60

# Proxy padrão no formulário de contas (host:porta:user:senha ou URL http://)
DEFAULT_PROXY=

# Bootstrap do primeiro admin (só se o banco estiver vazio)
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_IS_ADMIN=true

CELERY_CONCURRENCY=4

# ============================================================
# Web Push (VAPID) — https://vapidkeys.com/
# Notifica no celular a cada post com sucesso
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@dominio.com
